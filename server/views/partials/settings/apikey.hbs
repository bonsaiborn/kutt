<section id="apikey-wrapper">
  <h2>API</h2>
  <p>
    Papildus šai vietnei vari izmantot API, lai izveidotu, dzēstu un
    iegūtu saīsinātos URL. Ja nezini, kā darbojas API, neģenerē atslēgu. 
    NEKOPĪGO šo atslēgu savas vietnes klienta pusē. 
    <a href="https://docs.kutt.it" title="API dokumentācija" target="_blank">
      Lasīt API dokumentāciju.
    </a>
  </p>
  <div id="apikey">
    {{#if user.apikey}}
      <div class="clipboard small">
        <button 
          type="button"
          aria-label="Kopēt" 
          hx-on:click="handleShortURLCopyLink(this);" 
          data-url="{{user.apikey}}"
        >
        {{> icons/copy}}
        </button>
        {{> icons/check}}
      </div>
      <p 
        hx-on:click="handleShortURLCopyLink(this);" 
        data-url="{{user.apikey}}"
      >
        {{user.apikey}}
      </p>
    {{/if}}
    {{#if error}}
      <p class="error">{{error}}</p>
    {{/if}}
  </div>
  <form 
    hx-post="/api/auth/apikey"
    id="generate-apikey" 
    hx-target="#apikey-wrapper" 
    hx-swap="outerHTML"
  >
    <button type="submit" class="secondary">
      <span>{{> icons/zap}}</span>
      <span>{{> icons/spinner}}</span>
      {{#if user.apikey}}Reg{{else}}G{{/if}}enerate key
    </button>
  </form>
</section>