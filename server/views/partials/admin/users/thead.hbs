<thead>
  {{> admin/table_tab title='users'}}
  <tr class="controls users-controls with-filters">
    <th class="filters">
      <div>
        <div class="search-input-wrapper">
          <input 
            id="search" 
            name="search" 
            type="text" 
            placeholder="Meklēt lietotāju..." 
            class="table-input search admin" 
            hx-on:input="onSearchChange(event)" 
            hx-on:keyup="resetTableNav()"
            value="{{query.search}}"
          />
          <button 
            type="button" 
            aria-label="Notīrīt meklēšanu" 
            class="clear" 
            onclick="clearSeachInput(event)"
          >
            {{> icons/x}}
          </button>
        </div>
        <select  id="users-select-verified" name="verified" class="table-input verification" hx-on:change="resetTableNav()">
          <option value="">Verifikācija...</option>
          <option value="true" {{#ifEquals query.verified 'true'}}selected{{/ifEquals}}>Verificēts</option>
          <option value="false" {{#ifEquals query.verified 'false'}}selected{{/ifEquals}}>Nav verificēts</option>
        </select>
        <select id="users-select-banned" name="banned" class="table-input ban" hx-on:change="resetTableNav()">
          <option value="" selected>Bloķēšana...</option>
          <option value="true">Bloķēts</option>
          <option value="false">Nav bloķēts</option>
        </select>
        <select id="users-select-role" name="role" class="table-input role" hx-on:change="resetTableNav()">
          <option value="">Loma...</option>
          <option value="USER" {{#ifEquals query.role 'USER'}}selected{{/ifEquals}}>Lietotājs</option>
          <option value="ADMIN" {{#ifEquals query.role 'ADMIN'}}selected{{/ifEquals}}>Administrators</option>
        </select>
      </div>
      <div>
        <select id="users-select-domain" name="domains" class="table-input domains" hx-on:change="resetTableNav()">
          <option value="">Domēns...</option>
          <option value="true" {{#ifEquals query.domains 'true'}}selected{{/ifEquals}}>Ar domēniem</option>
          <option value="false" {{#ifEquals query.domains 'false'}}selected{{/ifEquals}}>Bez domēniem</option>
        </select>
        <select id="users-select-links" name="links" class="table-input links" hx-on:change="resetTableNav()">
          <option value="" selected>Saites...</option>
          <option value="true" {{#ifEquals query.links 'true'}}selected{{/ifEquals}}>Ar saitēm</option>
          <option value="false" {{#ifEquals query.links 'true'}}selected{{/ifEquals}}>Bez saitēm</option>
        </select>
        <input id="total" name="total" type="hidden" value="{{total}}" />
        <input id="limit" name="limit" type="hidden" value="10" />
        <input id="skip" name="skip" type="hidden" value="0" />
        <button 
          class="table primary"
          hx-on:click='openDialog("admin-table-dialog")' 
          hx-get="/create-user" 
          hx-target="#admin-table-dialog .content-wrapper" 
          hx-indicator="#admin-table-dialog"
        >
          <span>{{> icons/new_user}}</span>
          Izveidot lietotāju
        </button>
      </div>
    </th>
    {{> admin/table_nav}}
  </tr>
  <tr>
    <th class="users-id">ID</th>
    <th class="users-email">E-pasts</th>
    <th class="users-created-at">Izveidots</th>
    <th class="users-verified">Verificēts</th>
    <th class="users-role">Loma</th>
    <th class="users-links-count">Saišu skaits</th>
    <th class="users-actions"></th>
  </tr>
</thead>