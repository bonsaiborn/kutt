<thead>
  {{> admin/table_tab title='links'}}
  <tr class="controls links-controls with-filters">
    <th class="filters">
      <div>
        <div class="search-input-wrapper">
          <input 
            id="search" 
            name="search" 
            type="text" 
            placeholder="Meklēt saiti..." 
            class="table-input search admin" 
            hx-on:input="onSearchChange(event)" 
            hx-on:keyup="resetTableNav()"
            value="{{query.search}}"
          />
          <button 
            type="button" 
            aria-label="Notīrīt meklēšanu" 
            class="clear" 
            onclick="clearSeachInput(event)"
          >
            {{> icons/x}}
          </button>
        </div>
        <div class="search-input-wrapper">
          <input 
            id="search_domain" 
            name="domain" 
            type="text" 
            placeholder="Meklēt domēnu..." 
            class="table-input search admin" 
            hx-on:input="onSearchChange(event)" 
            hx-on:keyup="resetTableNav()"
            value="{{query.domain}}"
          />
          <button 
            type="button" 
            aria-label="Notīrīt lietotāja meklēšanu" 
            class="clear" 
            onclick="clearSeachInput(event)"
          >
            {{> icons/x}}
          </button>
        </div>
        <div class="search-input-wrapper">
          <input 
            id="search_user" 
            name="user" 
            type="text" 
            placeholder="Meklēt lietotāju..." 
            class="table-input search admin" 
            hx-on:input="onSearchChange(event)" 
            hx-on:keyup="resetTableNav()"
            value="{{query.user}}"
          />
          <button 
            type="button" 
            aria-label="Clear user search" 
            class="clear" 
            onclick="clearSeachInput(event)"
          >
            {{> icons/x}}
          </button>
        </div>
      </div>
      <div>
        <select 
          id="links-select-banned"
          name="banned"
          class="table-input ban"
          hx-on:change="resetTableNav()"
        >
          <option value="" selected>Bloķēšana...</option>
          <option value="true">Bloķēts</option>
          <option value="false">Nav bloķēts</option>
        </select>
        <select 
          id="links-select-anonymous"
          name="anonymous"
          class="table-input anonymous"
          hx-on:change="resetTableNav()"
        >
          <option value="">Anonimitāte...</option>
          <option value="true" {{#ifEquals query.anonymous 'true'}}selected{{/ifEquals}}>Anonīms</option>
          <option value="false" {{#ifEquals query.anonymous 'false'}}selected{{/ifEquals}}>Lietotājs</option>
        </select>
        <select 
          id="links-select-anonymous"
          name="has_domain"
          class="table-input has_domain"
          hx-on:change="resetTableNav()"
        >
          <option value="">Domēns...</option>
          <option value="true" {{#ifEquals query.has_domain 'true'}}selected{{/ifEquals}}>Ar domēnu</option>
          <option value="false" {{#ifEquals query.has_domain 'false'}}selected{{/ifEquals}}>Bez domēna</option>
        </select>
        <input id="total" name="total" type="hidden" value="{{total}}" />
        <input id="limit" name="limit" type="hidden" value="10" />
        <input id="skip" name="skip" type="hidden" value="0" />
      </div>
    </th>
    {{> admin/table_nav}}
  </tr>
  <tr>
    <th class="original-url">Sākotnējais URL</th>
    <th class="created-at">Izveidots</th>
    <th class="short-link">Īsā saite</th>
    <th class="views">Skatījumi</th>
    <th class="actions"></th>
  </tr>
</thead>